{
  "name": "@ikilote/magma-demo",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:all": "npm run test:lib:no-watch && npm run update-coverage-badges && npm run build:lib && npm run build:demo",
    "build:lib": "ng build @ikilote/magma --configuration production && cp *.md dist/ikilote/magma",
    "build:demo": "ng build magma-demo --configuration production && cp -r coverage dist/magma-demo/browser",
    "publish:lib": "cd dist/ikilote/magma && npm publish ",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint @ikilote/magma",
    "format": "npx prettier --write .",
    "test": "ng test",
    "test:lib": "ng test @ikilote/magma",
    "test:lib:no-watch": "ng test @ikilote/magma --watch=false",
    "update-coverage-badges": "node scripts/update-coverage-badges.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@ikilote/json2html": "^1.0.0",
    "@ikilote/num-formatter": "^1.0.0",
    "autosize": "^6.0.1",
    "bowser": "^2.14.1",
    "colorjs.io": "^0.6.1",
    "highlight.js": "11.11.1",
    "marked": "^18.0.4",
    "ng-select2-component": "^17.3.1",
    "ngx-highlightjs": "14.0.1",
    "ngx-markdown": "^21.3.0",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/autosize": "^4.0.3",
    "@types/node": "^25.9.1",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "baseline-browser-mapping": "^2.10.31",
    "cheerio": "^1.2.0",
    "jsdom": "^29.1.1",
    "ng-packagr": "^22.0.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-css-order": "^2.2.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.7"
  }
}

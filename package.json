{
  "name": "@ikilote/magma-demo",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:lib": "ng build @ikilote/magma --configuration production && cp *.md dist/ikilote/magma",
    "build:demo": "ng build magma-demo --configuration production && cp -r coverage dist/magma-demo/browser",
    "publish:lib": "cd dist/ikilote/magma && npm publish ",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint @ikilote/magma",
    "format": "npx prettier --write .",
    "test": "ng test",
    "test:lib": "ng test @ikilote/magma",
    "update-coverage-badges": "node scripts/update-coverage-badges.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@ikilote/json2html": "^1.0.0",
    "@ikilote/num-formatter": "^1.0.0",
    "autosize": "^6.0.1",
    "bowser": "^2.14.1",
    "colorjs.io": "^0.6.1",
    "highlight.js": "11.11.1",
    "marked": "^17.0.5",
    "ng-select2-component": "^17.2.9",
    "ngx-highlightjs": "14.0.1",
    "ngx-markdown": "^21.1.0",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/autosize": "^4.0.3",
    "@types/node": "^25.5.0",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "baseline-browser-mapping": "^2.10.13",
    "cheerio": "^1.2.0",
    "jsdom": "^29.0.1",
    "ng-packagr": "^21.2.2",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "prettier-plugin-css-order": "^2.2.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  }
}
